# Onion Core Environment Variables Reference
# Copy this file to .env and fill in your values

# ═══════════════════════════════════════════════════════════════════════════════
# OpenTelemetry Configuration
# ═══════════════════════════════════════════════════════════════════════════════

# OTLP endpoint for tracing/metrics export
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317

# Service name for observability
OTEL_SERVICE_NAME=onion-core-agent

# Tracing sampler (optional): parentbased_always_on, parentbased_traceidratio, etc.
OTEL_TRACES_SAMPLER=parentbased_always_on

# ═══════════════════════════════════════════════════════════════════════════════
# Redis Configuration (for distributed middlewares)
# ═══════════════════════════════════════════════════════════════════════════════

# Redis URL for distributed rate limiting, caching, and circuit breaking
ONION_REDIS_URL=redis://localhost:6379

# Redis connection pool size (default: 10)
ONION_REDIS_POOL_SIZE=10

# ═══════════════════════════════════════════════════════════════════════════════
# LLM Provider API Keys
# ═══════════════════════════════════════════════════════════════════════════════

# OpenAI API Key
OPENAI_API_KEY=sk-your-openai-api-key

# Anthropic API Key
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key

# ═══════════════════════════════════════════════════════════════════════════════
# Agent Configuration (Optional - can also be set in code)
# ═══════════════════════════════════════════════════════════════════════════════

# Default model (default: gpt-4)
ONION_DEFAULT_MODEL=gpt-4o

# Maximum steps per agent run (default: 10)
ONION_MAX_STEPS=10

# Maximum tokens per response (default: 4096)
ONION_MAX_TOKENS=4096

# Temperature for generation (default: 0.7)
ONION_TEMPERATURE=0.7

# System prompt (optional)
ONION_SYSTEM_PROMPT=You are a helpful AI assistant.

# ═══════════════════════════════════════════════════════════════════════════════
# Rate Limiting Configuration (Optional)
# ═══════════════════════════════════════════════════════════════════════════════

# Maximum requests per window (default: 60)
ONION_RATE_LIMIT_MAX_REQUESTS=60

# Window size in seconds (default: 60.0)
ONION_RATE_LIMIT_WINDOW=60.0

# Maximum tool calls per window (default: 30)
ONION_RATE_LIMIT_MAX_TOOL_CALLS=30

# Tool call window size in seconds (default: 120.0)
ONION_RATE_LIMIT_TOOL_CALL_WINDOW=120.0

# ═══════════════════════════════════════════════════════════════════════════════
# Cache Configuration (Optional)
# ═══════════════════════════════════════════════════════════════════════════════

# Cache TTL in seconds (default: 300)
ONION_CACHE_TTL=300

# Cache key strategy: full or user_only (default: full)
ONION_CACHE_KEY_STRATEGY=full

# ═══════════════════════════════════════════════════════════════════════════════
# Circuit Breaker Configuration (Optional)
# ═══════════════════════════════════════════════════════════════════════════════

# Failure threshold before opening circuit (default: 5)
ONION_CIRCUIT_BREAKER_FAILURE_THRESHOLD=5

# Recovery timeout in seconds (default: 30.0)
ONION_CIRCUIT_BREAKER_RECOVERY_TIMEOUT=30.0

# Success threshold to close circuit from half-open (default: 3)
ONION_CIRCUIT_BREAKER_SUCCESS_THRESHOLD=3

# ═══════════════════════════════════════════════════════════════════════════════
# Logging Configuration
# ═══════════════════════════════════════════════════════════════════════════════

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL (default: INFO)
ONION_LOG_LEVEL=INFO

# Log format: json or text (default: json)
ONION_LOG_FORMAT=json

# ═══════════════════════════════════════════════════════════════════════════════
# Health Check Server (Optional)
# ═══════════════════════════════════════════════════════════════════════════════

# Health check server port (default: 8080)
ONION_HEALTH_CHECK_PORT=8080

# Enable health check server (default: true)
ONION_HEALTH_CHECK_ENABLED=true
